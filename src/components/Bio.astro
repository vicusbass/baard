---
const stats = [
  { value: '2014', label: 'JOINED LEPROUS' },
  { value: '700+', label: 'SHOWS PLAYED' },
  { value: '1', label: 'SHIRT ON STAGE, RARELY' },
];
---

<section id="bio" class="section-shell">
  <p data-reveal class="eyebrow mb-[18px]">BIO</p>

  <div class="grid grid-cols-[repeat(auto-fit,minmax(300px,1fr))] items-start gap-[clamp(28px,5vw,64px)]">
    <div data-reveal>
      <h2 class="mb-5 text-[clamp(26px,4vw,40px)] leading-[1.15] font-bold tracking-[-.01em] text-pretty">
        From Oslo street corners to the engine room of progressive metal.
      </h2>
      <p class="m-0 text-[clamp(14px,1.6vw,16px)] leading-[1.75] text-bone/80 text-pretty">
        Baard learned dynamics the honest way — busking on Karl Johan. A national drum championship
        later, he became the rhythmic engine of Leprous, and a fixture in Rendezvous Point and ICS
        Vortex. Critics call him surgical. Audiences call him a force of nature. He'd probably just
        say he really likes drums.
      </p>

      <div class="mt-8 grid grid-cols-3 gap-4 border-t border-bone/12 pt-6">
        {stats.map(({ value, label }) => (
          <div>
            <div class="text-[clamp(24px,3vw,32px)] font-bold text-brass">{value}</div>
            <div class="mt-1 text-[10.5px] tracking-[.1em] text-bone/55">{label}</div>
          </div>
        ))}
      </div>
    </div>

    <div data-reveal class="relative aspect-4/5 min-h-80 overflow-hidden rounded">
      <img
        src="/baard-kolstad-drumeo.jpg"
        alt="Baard behind the kit"
        width="1400"
        height="933"
        loading="lazy"
        decoding="async"
        class="absolute inset-0 h-full w-full object-cover object-[48%_15%] grayscale-50 contrast-108"
      />
      <span class="absolute bottom-3.5 left-3.5 bg-ink/65 px-3 py-1.5 text-[10px] tracking-[.2em] text-bone/85 backdrop-blur-[4px]">
        NATURAL HABITAT
      </span>
    </div>
  </div>
</section>
