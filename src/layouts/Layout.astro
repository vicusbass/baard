---
import '@fontsource-variable/space-grotesk';
import 'lenis/dist/lenis.css';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogImageAlt?: string;
}

const {
  title,
  description,
  ogImage = '/og.jpg',
  ogImageAlt = 'Baard Kolstad behind his drum kit',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Baard Kolstad" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body class="bg-ink font-sans text-bone antialiased">
    <slot />
  </body>
</html>

<script>
  import Lenis from 'lenis';
  import Snap from 'lenis/snap';

  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const lenis = new Lenis({ autoRaf: true, anchors: true });
    window.__lenis = lenis;

    // Gentle magnet: when scrolling settles near the top of a section, ease onto it.
    const snap = new Snap(lenis, {
      type: 'proximity',
      distanceThreshold: '20%',
      duration: 0.9,
    });
    for (const section of document.querySelectorAll<HTMLElement>('main > section')) {
      snap.addElement(section, { align: 'start' });
    }
  }
</script>
